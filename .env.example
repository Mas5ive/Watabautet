PROJECT_NAME=Watabautet
SECRET_KEY=topsecret
FAILURE_COOLDOWN_SEC=600
SQLALCHEMY_ECHO=False


# POSTGRESQL 
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=0000
POSTGRES_DB=watabautet


# REDIS
REDIS_HOST=cache
