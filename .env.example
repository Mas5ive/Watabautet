REDIS_PASSWORD=1111


# RabbitMQ
RABBITMQ_HOST=broker
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=0000
RABBITMQ_NODE_PORT=5672


# Celery tasks
CELERY_RESULT_EXPIRES=86400
CELERY_TASK_MAX_RETRIES=3
CELERY_TASK_RETRY_DELAY=10
